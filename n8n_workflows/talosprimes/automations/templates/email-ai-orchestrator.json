{
  "name": "[TalosPrimes] Email IA - Orchestrateur autonome (multi-tenant)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "automations/email-ai-process",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "01. Email recu (webhook)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\n// Normaliser les champs (compatible IMAP + Gmail)\nconst tenantId = body.tenantId;\nconst from = body.from?.text || body.from || '';\nconst to = body.to?.text || body.to || '';\nconst subject = body.subject || '(sans objet)';\nconst textPlain = (body.textPlain || body.text || '').substring(0, 2000);\nconst threadId = body.threadId || null;\nconst emailId = body.emailId || body.id || null;\nconst hasAttachments = body.hasAttachments || (body.attachments || []).length > 0;\nconst provider = body.provider || 'imap'; // 'imap' ou 'gmail'\n\nif (!tenantId) {\n  return [{ json: { success: false, error: 'tenantId requis' } }];\n}\n\n// Ignorer les emails de notification systeme (noreply, mailer-daemon)\nconst fromLower = from.toLowerCase();\nconst ignorePatterns = ['noreply@', 'no-reply@', 'mailer-daemon@', 'postmaster@', 'bounce@'];\nconst shouldIgnore = ignorePatterns.some(p => fromLower.includes(p));\n\nreturn [{ json: {\n  tenantId, from, to, subject, textPlain,\n  threadId, emailId, hasAttachments, provider,\n  shouldIgnore, timestamp: new Date().toISOString()\n} }];"
      },
      "id": "normalize",
      "name": "02. Normaliser email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "should-ignore",
              "leftValue": "={{ $json.shouldIgnore }}",
              "rightValue": false,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "id": "check-ignore",
      "name": "03. Ignorer ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [690, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_WEBHOOK_URL || 'http://localhost:5678' }}/webhook/automations/email-ai-classify",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": { "timeout": 30000 }
      },
      "id": "call-classify",
      "name": "04. Classifier email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [910, 200]
    },
    {
      "parameters": {
        "jsCode": "const classResult = $input.first().json;\nconst data = classResult.data || classResult;\n\nif (!data.classification) {\n  return [{ json: { ...data, skip: true, skipReason: 'Classification echouee' } }];\n}\n\n// Ne pas repondre aux spams et newsletters\nconst skipCategories = ['spam', 'newsletter'];\nif (skipCategories.includes(data.classification.categorie)) {\n  return [{ json: { ...data, skip: true, skipReason: `Categorie ignoree: ${data.classification.categorie}` } }];\n}\n\nreturn [{ json: { ...data, skip: false } }];"
      },
      "id": "check-skip",
      "name": "05. Verifier categorie",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "not-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": false,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "id": "should-reply",
      "name": "06. Doit-on repondre ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1350, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "auto-reply",
              "leftValue": "={{ $json.action }}",
              "rightValue": "auto_reply",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "check-auto",
      "name": "07. Auto-repondable ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1570, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_WEBHOOK_URL || 'http://localhost:5678' }}/webhook/automations/email-ai-reply",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"tenantId\": \"{{ $json.tenantId }}\",\n  \"incomingLogId\": \"{{ $json.incomingLogId }}\",\n  \"from\": \"{{ $json.from }}\",\n  \"subject\": \"{{ $json.subject }}\",\n  \"textPlain\": {{ JSON.stringify($json.textPlain || '') }},\n  \"classification\": {{ JSON.stringify($json.classification) }},\n  \"threadId\": {{ $json.threadId ? '\"' + $json.threadId + '\"' : 'null' }},\n  \"emailId\": {{ $json.emailId ? '\"' + $json.emailId + '\"' : 'null' }}\n}",
        "options": { "timeout": 60000 }
      },
      "id": "call-reply",
      "name": "08. Generer reponse IA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1790, 0]
    },
    {
      "parameters": {
        "jsCode": "const replyResult = $input.first().json;\nconst data = replyResult.data || replyResult;\n\n// Verifier si l'IA recommande quand meme une review humaine\nif (data.needsHumanReview || data.confidence < 0.7) {\n  return [{ json: { ...data, finalAction: 'queue_human', reason: data.reason || 'Confidence < 0.7' } }];\n}\n\nreturn [{ json: { ...data, finalAction: 'send_now' } }];"
      },
      "id": "check-confidence",
      "name": "09. Confiance suffisante ?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2010, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "send-now",
              "leftValue": "={{ $json.finalAction }}",
              "rightValue": "send_now",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "check-send",
      "name": "10. Envoyer ou file d'attente ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2230, 0]
