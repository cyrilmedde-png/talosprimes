    {
      "parameters": {
        "jsCode": "// Collecter le resultat final de toutes les branches\nconst sources = [\n  $('12. Marquer envoye').first()?.json,\n  $('11b. Mettre en file d\\'attente').first()?.json,\n  $('07b. En file (cas complexe)').first()?.json\n].filter(Boolean);\n\nconst classify = $('05. Verifier categorie').first()?.json;\n\nreturn [{ json: {\n  success: true,\n  data: {\n    tenantId: classify?.tenantId,\n    from: classify?.from,\n    subject: classify?.subject,\n    classification: classify?.classification,\n    action: classify?.action,\n    processed: true,\n    timestamp: new Date().toISOString()\n  }\n} }];"
      },
