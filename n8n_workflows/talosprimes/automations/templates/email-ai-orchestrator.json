      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE email_incoming_logs SET\n  reply_action = 'queue_human',\n  updated_at = NOW()\nWHERE id = '{{ $json.incomingLogId }}'::uuid",
        "options": {}
      },
      "id": "queue-complex",
      "name": "07b. En file (cas complexe)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1790, 200],
      "credentials": { "postgres": { "name": "Supabase Postgres" } }
