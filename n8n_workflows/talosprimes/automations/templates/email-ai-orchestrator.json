        "url": "={{ $env.N8N_WEBHOOK_URL || 'http://localhost:5678' }}/webhook/automations/email-send",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"tenantId\": \"{{ $json.tenantId }}\",\n  \"to\": \"{{ $json.to }}\",\n  \"subject\": \"{{ $json.replySubject }}\",\n  \"text\": {{ JSON.stringify($json.replyText || '') }},\n  \"html\": {{ JSON.stringify($json.replyHtml || '') }}\n}",
        "options": { "timeout": 30000 }
      },
