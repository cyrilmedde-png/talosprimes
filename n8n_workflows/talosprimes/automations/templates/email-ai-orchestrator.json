    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE email_incoming_logs SET\n  reply_sent_at = NOW(),\n  reply_action = 'sent_auto',\n  updated_at = NOW()\nWHERE id = '{{ $('09. Confiance suffisante ?').first().json.incomingLogId }}'::uuid",
        "options": {}
      },
