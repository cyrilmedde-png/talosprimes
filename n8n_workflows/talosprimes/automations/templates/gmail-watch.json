{
  "name": "[TalosPrimes] Email - Surveillance (multi-tenant)",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [{ "mode": "everyMinute" }]
        },
        "options": {
          "labelIds": ["INBOX"]
        }
      },
      "id": "gmail-trigger",
      "name": "01. Nouveau email Gmail",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [250, 300],
      "credentials": {
        "gmailOAuth2": {
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const email = $input.first().json;\n\nreturn [{ json: {\n  id: email.id || null,\n  threadId: email.threadId || null,\n  from: email.from || '',\n  to: email.to || '',\n  subject: email.subject || '(sans objet)',\n  date: email.date || new Date().toISOString(),\n  snippet: email.snippet || '',\n  textPlain: (email.textPlain || '').substring(0, 1000),\n  labels: email.labelIds || [],\n  hasAttachments: (email.attachments || []).length > 0,\n  action: 'received'\n} }];"
      },
      "id": "process",
      "name": "02. Traiter email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst tenantId = '{{ TENANT_ID }}';\n\nconsole.log(`[Gmail recu] De: ${data.from} | Sujet: ${data.subject}`);\n\nreturn [{ json: { ...data, tenantId, provider: 'gmail', timestamp: new Date().toISOString() } }];"
      },
      "id": "add-tenant",
      "name": "03. Ajouter tenantId",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_WEBHOOK_URL || 'http://localhost:5678' }}/webhook/automations/email-ai-process",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": { "timeout": 90000 }
      },
      "id": "call-orchestrator",
      "name": "04. Envoyer a l'agent IA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [910, 300]
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconsole.log(`[Agent IA Gmail] Resultat: ${JSON.stringify(result.data || result)}`);\nreturn [{ json: result }];"
      },
      "id": "log-result",
      "name": "05. Logger resultat",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 300]
    }
  ],
  "connections": {
    "01. Nouveau email Gmail": { "main": [[{ "node": "02. Traiter email", "type": "main", "index": 0 }]] },
    "02. Traiter email": { "main": [[{ "node": "03. Ajouter tenantId", "type": "main", "index": 0 }]] },
    "03. Ajouter tenantId": { "main": [[{ "node": "04. Envoyer a l'agent IA", "type": "main", "index": 0 }]] },
    "04. Envoyer a l'agent IA": { "main": [[{ "node": "05. Logger resultat", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "talosprimes" }, { "name": "auto-email" }]
}
