{
  "name": "[{{ CLIENT_NAME }}] Gmail - Envoi",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "client/{{ CLIENT_CODE }}/gmail-send",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "01. Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst to = body.to;\nconst subject = body.subject;\nconst message = body.message || body.text || '';\nconst html = body.html || '';\nconst cc = body.cc || '';\nconst bcc = body.bcc || '';\n\nif (!to || !subject) {\n  return [{ json: { success: false, error: 'Destinataire (to) et sujet (subject) requis' } }];\n}\n\nreturn [{ json: { to, subject, message, html, cc, bcc, valid: true } }];"
      },
      "id": "validate",
      "name": "02. Valider",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.to }}",
        "subject": "={{ $json.subject }}",
        "message": "={{ $json.message }}",
        "options": {
          "ccList": "={{ $json.cc }}",
          "bccList": "={{ $json.bcc }}",
          "appendAttribution": false
        }
      },
      "id": "gmail-send",
      "name": "03. Envoyer Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [690, 300],
      "credentials": {
        "gmailOAuth2": {
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const data = $('02. Valider').first().json;\nconst result = $input.first().json;\n\nreturn [{ json: {\n  success: true,\n  data: {\n    message: 'Email envoye avec succes via Gmail',\n    messageId: result.id || null,\n    threadId: result.threadId || null,\n    to: data.to,\n    subject: data.subject\n  }\n} }];"
      },
      "id": "result",
      "name": "04. Resultat",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [910, 300]
    },
    {
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {}
      },
      "id": "respond",
      "name": "05. Repondre",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1130, 300]
    }
  ],
  "connections": {
    "01. Webhook": { "main": [[{ "node": "02. Valider", "type": "main", "index": 0 }]] },
    "02. Valider": { "main": [[{ "node": "03. Envoyer Gmail", "type": "main", "index": 0 }]] },
    "03. Envoyer Gmail": { "main": [[{ "node": "04. Resultat", "type": "main", "index": 0 }]] },
    "04. Resultat": { "main": [[{ "node": "05. Repondre", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "talosprimes" }, { "name": "auto-email" }, { "name": "gmail" }]
}
