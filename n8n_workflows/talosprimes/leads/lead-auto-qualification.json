    {
      "parameters": {
        "jsCode": "// Préparer actions pour auto-qualification\nvar pgResult = $input.first().json;\nvar leadData = pgResult.data && pgResult.data.length > 0 ? pgResult.data[0] : null;\n\nif (!leadData) {\n  throw new Error('Lead not found');\n}\n\nvar prenom = leadData.prenom || '';\nvar smsText = `Bonjour ${prenom}, merci pour votre appel ! L'équipe TalosPrimes vous recontactera sous 24h. En attendant, découvrez nos solutions sur talosprimes.com`;\n\nvar updateQuery = `\nUPDATE leads\nSET statut = 'contacte', date_contact = NOW(), updated_at = NOW()\nWHERE id = '${leadData.id}'::uuid\nRETURNING id, nom, prenom, telephone, statut, date_contact\n`;\n\n// Prepare internal lead_scoring call\nvar leadScoringWebhookBody = {\n  event: 'lead.auto_scored',\n  lead_id: leadData.id,\n  source: 'lead_auto_qualification'\n};\n\nreturn [{ json: { \n  leadId: leadData.id, \n  nom: leadData.nom, \n  prenom: leadData.prenom, \n  telephone: leadData.telephone,\n  smsText: smsText,\n  updateQuery: updateQuery,\n  leadScoringPayload: leadScoringWebhookBody\n} }];"
      },
