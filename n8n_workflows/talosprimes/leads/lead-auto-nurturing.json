        "jsCode": "// Pour les relances normales, préparer notification Telegram\nvar parentData = $('08. Vérifier si abandonner').first().json;\nvar parentContext = $('05. Préparer relances').first().json;\nvar selectData = $('09. Postgres - GET lead').first().json;\nvar leadInfo = selectData.data && selectData.data[0] ? selectData.data[0] : {};\n\nreturn [{ json: { ...parentData, leadInfo: leadInfo, notifyRelance: true } }];"
