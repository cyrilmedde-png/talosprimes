    {
      "parameters": {
        "jsCode": "// Construire les requêtes SQL pour le dashboard\n// 1. COUNT by statut\n// 2. COUNT total leads this month\n// 3. AVG score\n// 4. Leads with score > 70\n// 5. Conversion rate\n\nvar queries = [\n  // Query 1: Count by statut\n  `SELECT statut, COUNT(*) as count FROM leads GROUP BY statut`,\n  // Query 2: Count total this month\n  `SELECT COUNT(*) as total FROM leads WHERE created_at >= DATE_TRUNC('month', NOW())`,\n  // Query 3: Average score\n  `SELECT COALESCE(AVG(CAST(score AS NUMERIC)), 0) as avg_score FROM leads`,\n  // Query 4: Hot leads (score > 70)\n  `SELECT id, nom, prenom, email, telephone, score FROM leads WHERE score > 70 ORDER BY score DESC LIMIT 20`,\n  // Query 5: Conversion rate\n  `SELECT COUNT(*) FILTER (WHERE statut = 'converti') as converti, COUNT(*) as total FROM leads`\n];\n\nreturn [{ json: { queries: queries } }];"
      },
      "id": "Code_BuildQueries",
      "name": "02. Construire les requêtes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        400
      ]
    },
