    {
      "parameters": {
        "jsCode": "// Formatter les résultats en JSON clean pour le dashboard\nvar byStatut = $('03a. Postgres - COUNT by statut').first().json.data || [];\nvar thisMonth = $('03b. Postgres - COUNT this month').first().json.data || [{}];\nvar avgScore = $('03c. Postgres - AVG score').first().json.data || [{}];\nvar hotLeads = $('03d. Postgres - Hot leads').first().json.data || [];\nvar conversionData = $('03e. Postgres - Conversion rate').first().json.data || [{}];\n\n// Build status map\nvar statusMap = {};\nbyStatut.forEach(function(row) {\n  statusMap[row.statut] = parseInt(row.count || 0);\n});\n\n// Ensure all statuses exist\nvar statuses = ['nouveau', 'contacte', 'qualifie', 'converti', 'abandonne'];\nstatuses.forEach(function(s) {\n  if (!statusMap[s]) statusMap[s] = 0;\n});\n\n// Get metrics\nvar totalThisMonth = parseInt(thisMonth[0]?.total || 0);\nvar averageScore = parseFloat(avgScore[0]?.avg_score || 0).toFixed(2);\nvar conversionRate = 0;\nif (conversionData[0] && conversionData[0].total > 0) {\n  conversionRate = ((parseInt(conversionData[0].converti || 0) / parseInt(conversionData[0].total)) * 100).toFixed(2);\n}\n\n// Build hot leads list\nvar hotLeadsList = hotLeads.map(function(lead) {\n  return {\n    id: lead.id,\n    nom: lead.nom,\n    prenom: lead.prenom,\n    email: lead.email,\n    telephone: lead.telephone,\n    score: parseInt(lead.score || 0)\n  };\n});\n\n// Build dashboard response\nvar dashboard = {\n  timestamp: new Date().toISOString(),\n  summary: {\n    totalLeadsThisMonth: totalThisMonth,\n    averageScore: parseFloat(averageScore),\n    conversionRate: parseFloat(conversionRate)\n  },\n  byStatus: statusMap,\n  hotLeads: hotLeadsList,\n  hotLeadsCount: hotLeadsList.length\n};\n\nreturn [{ json: dashboard }];"
      },
