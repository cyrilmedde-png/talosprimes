        "jsCode": "var raw=$input.first().json;\nfunction pj(x){if(typeof x!=='string')return x;try{return JSON.parse(x)}catch(e){return null}}\nfunction isO(v){return v!==null&&typeof v==='object'&&!Array.isArray(v)}\nfunction g(o,k1,k2){if(!isO(o))return null;var v=o[k1];if(v!=null&&v!=='')return v;if(k2){v=o[k2];if(v!=null&&v!=='')return v}return null}\nvar payload=isO(raw)?raw:{};\nif(isO(raw)&&raw.body!==undefined)payload=typeof raw.body==='string'?pj(raw.body):raw.body;\nif(!isO(payload))payload={};\nvar data=isO(payload.data)?payload.data:payload;\nif(!isO(data))data=payload;\nvar tenantId=g(data,'tenantId','tenant_id')||g(payload,'tenantId','tenant_id')||g(raw,'tenantId');\nvar siteId=g(data,'siteId','site_id')||g(payload,'siteId','site_id');\nif(!tenantId||!siteId)return [{json:{_error:true,message:'tenantId et siteId requis'}}];\nvar body={tenantId,siteId};\nvar cd=g(data,'code')||g(payload,'code');if(cd)body.code=cd;\nvar dg=g(data,'designation')||g(payload,'designation');if(dg)body.designation=dg;\nreturn [{json:body}];"
