        "jsCode": "var p = $('02. Parser').first().json;\nvar updates = [];\nif(p.code) { var code = (p.code || '').replace(/'/g, \"''\"); updates.push(`code = '${code}'`); }\nif(p.designation) { var dsg = (p.designation || '').replace(/'/g, \"''\"); updates.push(`designation = '${dsg}'`); }\nupdates.push('updated_at = NOW()');\nvar setClause = updates.join(', ');\nvar query = `UPDATE stock_sites SET ${setClause} WHERE id = '${p.siteId}' AND tenant_id = '${p.tenantId}' RETURNING *`;\nreturn [{json:{query}}];"
