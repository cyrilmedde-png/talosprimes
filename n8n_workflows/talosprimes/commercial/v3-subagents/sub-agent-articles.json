{
  "name": "Sub-Agent Articles - TalosPrimes v3",
  "nodes": [
    {
      "id": "1041",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ],
      "name": "Workflow Trigger",
      "parameters": {}
    },
    {
      "id": "1044",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        400,
        0
      ],
      "name": "Agent Articles",
      "parameters": {
        "options": {
          "systemMessage": "Tu es le spécialiste du catalogue d'articles pour TalosPrimes.\n\nOutils :\n- lister_articles : voir tout le catalogue (code, désignation, prix HT, TVA, unité)\n- rechercher_article : chercher un article par code ou désignation\n- creer_article : créer un nouvel article\n\nRÈGLES :\n- Le code article est en MAJUSCULES (ex: AUDIT-01, PACK-BIZ, SETBIZ)\n- Le prix est en HT (hors taxes)\n- La TVA est en pourcentage (20 = 20%)\n- Unités possibles : unité, heure, jour, forfait, mois",
          "maxIterations": 5
        },
        "text": "={{ $json.chatInput || $json.query || $json.message || '' }}"
      }
    },
    {
      "id": "1042",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [
        400,
        200
      ],
      "name": "OpenAI Chat Model",
      "parameters": {
        "model": "gpt-4o-2024-11-20",
        "options": {
          "temperature": 0.1
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "MmpYHYAt746xfTrB",
          "name": "OpenAi account"
        }
      }
    },
    {
      "id": "1043",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.3,
      "position": [
        600,
        200
      ],
      "name": "Simple Memory",
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "={{ $json.sessionId || 'default' }}",
        "contextWindowLength": 15
      }
    },
    {
      "id": "1045",
      "type": "@n8n/n8n-nodes-langchain.toolPostgres",
      "typeVersion": 1,
      "position": [
        200,
        400
      ],
      "name": "lister_articles",
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, code, designation, prix_unitaire_ht, tva_taux, unite FROM article_codes ORDER BY code",
        "description": "Lister tous les articles du catalogue avec code, désignation, prix et TVA.",
        "descriptionType": "manual"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "id": "1046",
      "type": "@n8n/n8n-nodes-langchain.toolPostgres",
      "typeVersion": 1,
      "position": [
        400,
        400
      ],
      "name": "rechercher_article",
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, code, designation, prix_unitaire_ht, tva_taux, unite FROM article_codes WHERE code ILIKE '%' || '{{ $fromAI(\"search\", \"Code ou mot-clé de l article\") }}' || '%' OR designation ILIKE '%' || '{{ $fromAI(\"search\", \"Mot-clé\") }}' || '%'",
        "description": "Chercher un article par code ou désignation.",
        "descriptionType": "manual"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "id": "1047",
      "type": "@n8n/n8n-nodes-langchain.toolPostgres",
      "typeVersion": 1,
      "position": [
        600,
        400
      ],
      "name": "creer_article",
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO article_codes (code, designation, prix_unitaire_ht, tva_taux, unite) VALUES ('{{ $fromAI(\"code\", \"Code en MAJUSCULES, ex: AUDIT-01\") }}', '{{ $fromAI(\"designation\", \"Nom/description de l article\") }}', {{ $fromAI(\"prixHt\", \"Prix unitaire HT en euros, nombre\") }}, {{ $fromAI(\"tvaTaux\", \"Taux TVA en pourcentage, defaut 20\") }}, '{{ $fromAI(\"unite\", \"Unite: unite, heure, jour, forfait, mois\") }}') RETURNING id, code, designation, prix_unitaire_ht, tva_taux",
        "description": "Créer un nouvel article dans le catalogue.",
        "descriptionType": "manual"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    }
  ],
