        600,
        400
      ],
      "name": "obtenir_devis",
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT d.*, json_agg(json_build_object('designation', dl.designation, 'quantite', dl.quantite, 'prix_unitaire_ht', dl.prix_unitaire_ht, 'total_ht', dl.total_ht, 'code_article', dl.code_article)) FILTER (WHERE dl.id IS NOT NULL) as lignes FROM devis d LEFT JOIN devis_lines dl ON dl.devis_id = d.id WHERE d.id = '{{ $fromAI(\"devisId\", \"UUID du devis\") }}' GROUP BY d.id",
        "description": "Obtenir les détails d'un devis par son UUID, incluant ses lignes.",
        "descriptionType": "manual"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
