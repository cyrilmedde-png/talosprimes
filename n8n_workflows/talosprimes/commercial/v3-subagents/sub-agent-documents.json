      "name": "chercher_client_pour_document",
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, type, nom, prenom, email, telephone, raison_sociale FROM client_finals WHERE nom ILIKE '%' || '{{ $fromAI(\"search\", \"Mot-clé simple: le nom de famille seul\") }}' || '%' OR prenom ILIKE '%' || '{{ $fromAI(\"search\", \"Mot-clé\") }}' || '%' OR raison_sociale ILIKE '%' || '{{ $fromAI(\"search\", \"Mot-clé\") }}' || '%' LIMIT 10",
        "description": "UTILISER EN PREMIER. Chercher un client par nom pour obtenir son UUID (champ id). Utilise un seul mot-clé.",
        "descriptionType": "manual"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
