      "name": "creer_devis",
      "parameters": {
        "method": "POST",
        "url": "https://api.talosprimes.com/api/devis",
        "description": "Créer un devis avec PLUSIEURS lignes d'articles en une seule fois. AVANT: chercher le client (UUID) et les articles (prix). Le body contient clientFinalId, montantHt, tvaTaux, description, modePaiement, lines (tableau de TOUTES les lignes).",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  JSON.stringify({\n    clientFinalId: $fromAI(\"clientFinalId\", \"UUID du client obtenu via chercher_client_pour_document\"),\n    montantHt: Number($fromAI(\"montantHt\", \"Montant total HT = somme de (quantite x prixUnitaireHt) pour chaque ligne\")) || 0,\n    tvaTaux: Number($fromAI(\"tvaTaux\", \"Taux TVA en pourcentage, defaut 20\")) || 0,\n    description: $fromAI(\"description\", \"Description courte du devis\"),\n    modePaiement: $fromAI(\"modePaiement\", \"Mode: virement, cheque, cb, prelevement. Defaut: virement\"),\n    lines: (() => { try { return JSON.parse($fromAI(\"lines\", 'Tableau JSON de TOUTES les lignes du devis. TOUJOURS mettre TOUTES les lignes dans UN SEUL appel. Exemple avec 3 lignes: [{\\\"designation\\\":\\\"Audit SEO\\\",\\\"quantite\\\":1,\\\"prixUnitaireHt\\\":1500},{\\\"designation\\\":\\\"Redaction contenu\\\",\\\"quantite\\\":5,\\\"prixUnitaireHt\\\":200},{\\\"designation\\\":\\\"Formation\\\",\\\"quantite\\\":2,\\\"prixUnitaireHt\\\":800}]')); } catch(e) { return []; } })()\n  })\n}}"
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "FLSZWCszgEFfXDoK",
          "name": "API TalosPrimes"
        }
      }
    },
