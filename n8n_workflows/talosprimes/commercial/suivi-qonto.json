        }
      }
    },
    {
      "parameters": {
        "url": "=https://thirdparty.qonto.com/v2/transactions?slug={{ $json.organization.bank_accounts[0].slug }}&settled_at_from={{ $now.minus({hours: 4}).toUTC().toISO() }}&per_page=100&sort_by=settled_at:desc",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [440, 0],
      "id": "a1b2c3d4-0003-4000-8000-000000000003",
      "name": "Transactions récentes",
      "credentials": {
        "httpHeaderAuth": {
          "id": "",
          "name": "Qonto API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has_transactions",
              "leftValue": "={{ $json.transactions?.length || 0 }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, 0],
      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "Nouvelles transactions ?"
    },
    {
      "parameters": {
        "jsCode": "// Préparer le résumé des transactions\nconst data = $input.first().json;\nconst transactions = data.transactions || [];\n\nlet totalCredits = 0;\nlet totalDebits = 0;\nconst lines = [];\n\nfor (const t of transactions) {\n  const emoji = t.side === 'credit' ? '💰' : '💸';\n  const sign = t.side === 'credit' ? '+' : '-';\n  const amount = t.amount.toFixed(2);\n  lines.push(`${emoji} ${sign}${amount}€ — ${t.label}`);\n  \n  if (t.side === 'credit') totalCredits += t.amount;\n  else totalDebits += t.amount;\n}\n\nconst net = (totalCredits - totalDebits).toFixed(2);\nconst netEmoji = totalCredits >= totalDebits ? '📈' : '📉';\n\nconst message = `🏦 *Mouvements Qonto* (${transactions.length} transaction${transactions.length > 1 ? 's' : ''})\n\n${lines.join('\\n')}\n\n───────────────\n💰 Entrées: +${totalCredits.toFixed(2)}€\n💸 Sorties: -${totalDebits.toFixed(2)}€\n${netEmoji} Net: ${net}€\n🕐 ${new Date().toLocaleString('fr-FR', { timeZone: 'Europe/Paris' })}`;\n\nreturn [{ json: { telegramMessage: message, targetChatId: '6296082748' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, -80],
      "id": "a1b2c3d4-0005-4000-8000-000000000005",
      "name": "Résumé transactions"
    },
    {
      "parameters": {
        "chatId": "={{ $json.targetChatId }}",
        "text": "={{ $json.telegramMessage }}",
        "additionalFields": {
          "appendAttribution": false,
          "parse_mode": "Markdown"
        }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1100, -80],
      "id": "a1b2c3d4-0006-4000-8000-000000000006",
      "name": "Notification Telegram",
      "credentials": {
        "telegramApi": {
          "id": "JeSjY5sE3QcncJ4u",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [880, 80],
      "id": "a1b2c3d4-0007-4000-8000-000000000007",
      "name": "Pas de nouvelles transactions"
    }
  ],
