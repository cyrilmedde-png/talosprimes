            }
          ]
        }
      }
    },
    {
      "id": "17f2a03f-5f01-4948-bc8c-83863e49a103",
      "name": "Get BDC",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        500,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT bc.*, json_agg(json_build_object('description', bcl.description, 'quantite', bcl.quantite, 'prix_unitaire_ht', bcl.prix_unitaire_ht, 'montant_ht', bcl.montant_ht)) as lignes FROM bons_commande bc LEFT JOIN bons_commande_lines bcl ON bcl.bon_commande_id = bc.id WHERE bc.tenant_id = '{{ $json.tenant_id }}' AND bc.id = '{{ $json.bdc_id }}' GROUP BY bc.id"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "id": "2abaa521-dd7a-44e6-aa97-c144d17e4950",
      "name": "Create Facture from BDC",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        750,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH new_facture AS (INSERT INTO invoices (id, tenant_id, numero, client_final_id, bon_commande_id, montant_ht, tva, montant_ttc, statut, created_at) SELECT gen_random_uuid(), tenant_id, 'FAC-' || LPAD((SELECT COALESCE(MAX(CAST(SUBSTRING(numero FROM 5) AS INTEGER)), 0) + 1 FROM invoices WHERE tenant_id = bc.tenant_id)::text, 4, '0'), client_final_id, id, montant_ht, tva, montant_ttc, 'brouillon', NOW() FROM bons_commande bc WHERE id = '{{ $json.bdc_id }}' RETURNING *) UPDATE bons_commande SET statut = 'facture' WHERE id = '{{ $json.bdc_id }}'"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    }
  ],
