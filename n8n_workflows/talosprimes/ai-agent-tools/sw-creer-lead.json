      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO leads (id, tenant_id, nom, email, telephone, source, statut, created_at) VALUES (gen_random_uuid(), '{{ $json.tenant_id }}', '{{ $json.nom }}', '{{ $json.email }}', '{{ $json.telephone }}', '{{ $json.source }}', 'nouveau', NOW()) RETURNING *"
      },
