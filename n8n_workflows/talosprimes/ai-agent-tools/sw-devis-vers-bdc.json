{
  "name": "SW - Devis vers BDC",
  "nodes": [
    {
      "id": "fd2cce5a-aa11-4c3d-8e9f-2a1b5c9d8f0e",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        0,
        300
      ],
      "parameters": {}
    },
    {
      "id": "a7f4b5c3-bb22-4a9c-8f3b-1c5d7e9f0a2b",
      "name": "Validation",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        250,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": ""
          },
          "conditions": [
            {
              "leftValue": "={{ $json.tenant_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              }
            },
            {
              "leftValue": "={{ $json.devis_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "b9c8e7f6-cc33-3c2b-1a0f-9e8d7c6b5a4f",
      "name": "Erreur Validation",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        500,
        500
      ],
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "err-devis-bdc-01",
              "name": "error",
              "value": "Champs requis manquants: tenant_id, devis_id",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "c2d5e9f8-dd44-4c5d-8e9f-0a1b2c3d4e5f",
      "name": "Get Devis",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        500,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT d.*, json_agg(json_build_object('designation', dl.designation, 'quantite', dl.quantite, 'prix_unitaire_ht', dl.prix_unitaire_ht, 'total_ht', dl.total_ht, 'ordre', dl.ordre, 'code_article', dl.code_article)) as lignes FROM devis d LEFT JOIN devis_lines dl ON dl.devis_id = d.id WHERE d.tenant_id = '{{ $json.tenant_id }}' AND d.id = '{{ $json.devis_id }}' GROUP BY d.id"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "id": "d3f6a9b2-ee55-4d7f-9a0b-5c2d3e4f5a6b",
      "name": "Get Next BDC Numero",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        750,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COALESCE(MAX(CAST(SUBSTRING(numero FROM 5) AS INTEGER)), 0) + 1 as next_num FROM bons_commande WHERE tenant_id = '{{ $json.tenant_id }}'"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "id": "e4a7b1c5-ff66-4e9c-3a0b-6d5f7a8b9c0d",
      "name": "Create BDC from Devis",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1000,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH new_bdc AS (INSERT INTO bons_commande (id, tenant_id, numero, client_final_id, devis_id, montant_ht, tva, montant_ttc, statut, created_at) VALUES (gen_random_uuid(), '{{ $json.tenant_id }}', 'BDC-' || LPAD({{ $json.next_num }}::text, 4, '0'), '{{ $json.client_final_id }}', '{{ $('Execute Workflow Trigger').item.json.devis_id }}'::uuid, {{ $json.montant_ht }}, {{ $json.tva }}, {{ $json.montant_ttc }}, 'brouillon', NOW()) RETURNING *), update_devis AS (UPDATE devis SET statut = 'commandee', updated_at = NOW() WHERE id = '{{ $('Execute Workflow Trigger').item.json.devis_id }}'::uuid) SELECT * FROM new_bdc"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "id": "f5b8c2d6-0077-5f0d-4b1c-7e6a8d9f0a1b",
      "name": "Copy Lines to BDC",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1250,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO bon_commande_lines (id, bon_commande_id, code_article, designation, quantite, prix_unitaire_ht, total_ht, ordre) SELECT gen_random_uuid(), '{{ $json.id }}'::uuid, dl.code_article, dl.designation, dl.quantite, dl.prix_unitaire_ht, dl.total_ht, dl.ordre FROM devis_lines dl WHERE dl.devis_id = '{{ $('Execute Workflow Trigger').item.json.devis_id }}'::uuid RETURNING *"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      }
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
        [
          {
            "node": "Validation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Validation": {
