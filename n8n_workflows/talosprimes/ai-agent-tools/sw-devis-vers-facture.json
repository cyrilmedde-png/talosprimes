      "id": "b9c8e7f6-5a4d-3c2b-1a0f-9e8d7c6b5a4f",
      "name": "Erreur Validation",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        650,
        450
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "query",
        "query": "SELECT d.*, json_agg(json_build_object('designation', dl.designation, 'quantite', dl.quantite, 'prix_unitaire_ht', dl.prix_unitaire_ht, 'total_ht', dl.total_ht, 'ordre', dl.ordre, 'code_article', dl.code_article)) as lignes FROM devis d LEFT JOIN devis_lines dl ON dl.devis_id = d.id WHERE d.tenant_id = '{{ $json.tenant_id }}' AND d.id = '{{ $json.devis_id }}' GROUP BY d.id",
        "postgresCredentialType": "postgresConnectionString"
      },
      "id": "c2d5e9f8-7a6b-4c5d-8e9f-0a1b2c3d4e5f",
      "name": "Get Devis",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 4.3,
      "position": [
        650,
        300
      ],
      "credentials": {
        "postgres": "OGqj65ZoFRileCck"
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "query",
        "query": "SELECT COALESCE(MAX(CAST(SUBSTRING(numero FROM 5) AS INTEGER)), 0) + 1 as next_num FROM invoices WHERE tenant_id = '{{ $json.tenant_id }}'",
        "postgresCredentialType": "postgresConnectionString"
      },
      "id": "d3f6a9b2-1c8e-4d7f-9a0b-5c2d3e4f5a6b",
      "name": "Get Next FAC Numero",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 4.3,
      "position": [
        850,
        300
      ],
      "credentials": {
        "postgres": "OGqj65ZoFRileCck"
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "query",
        "query": "WITH new_facture AS (\n  INSERT INTO invoices (id, type, tenant_id, numero, client_final_id, devis_id, montant_ht, tva, montant_ttc, statut, created_at)\n  VALUES (gen_random_uuid(), 'vente', '{{ $json.tenant_id }}', 'FAC-' || LPAD({{ $json.next_num }}::text, 4, '0'), '{{ $json.client_final_id }}', '{{ $('Execute Workflow Trigger').item.json.devis_id }}'::uuid, {{ $json.montant_ht }}, {{ $json.tva }}, {{ $json.montant_ttc }}, 'brouillon', NOW())\n  RETURNING *\n), update_devis AS (\n  UPDATE devis SET statut = 'facturee', updated_at = NOW() WHERE id = '{{ $('Execute Workflow Trigger').item.json.devis_id }}'::uuid\n)\nSELECT * FROM new_facture",
        "postgresCredentialType": "postgresConnectionString"
      },
      "id": "e4a7b1c5-2f8d-4e9c-3a0b-6d5f7a8b9c0d",
      "name": "Create Facture from Devis",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 4.3,
      "position": [
        1050,
        300
      ],
      "credentials": {
        "postgres": "OGqj65ZoFRileCck"
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "query",
        "query": "INSERT INTO invoice_lines (id, invoice_id, code_article, designation, quantite, prix_unitaire_ht, total_ht, ordre)\nSELECT gen_random_uuid(), '{{ $json.id }}'::uuid, dl.code_article, dl.designation, dl.quantite, dl.prix_unitaire_ht, dl.total_ht, dl.ordre\nFROM devis_lines dl\nWHERE dl.devis_id = '{{ $('Execute Workflow Trigger').item.json.devis_id }}'::uuid\nRETURNING *",
        "postgresCredentialType": "postgresConnectionString"
      },
      "id": "f5b8c2d6-3a9e-5f0d-4b1c-7e6a8d9f0a1b",
      "name": "Copy Lines to Invoice",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 4.3,
      "position": [
        1250,
        300
      ],
      "credentials": {
        "postgres": "OGqj65ZoFRileCck"
      }
    }
