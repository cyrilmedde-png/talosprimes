        "operation": "executeQuery",
        "resource": "query",
        "query": "SELECT f.id, f.tenant_id, f.client_id, f.date, f.montant_ht, f.montant_tva, f.montant_ttc, f.taux_tva, c.siret, c.tva_number, c.pays FROM factures f LEFT JOIN clients c ON f.client_id = c.id WHERE f.tenant_id = $1 AND f.date >= $2 AND f.date <= $3 AND ((($4 = 'B2C' AND (c.siret IS NULL OR c.tva_number IS NULL)) OR ($4 = 'INTERNATIONAL' AND c.pays != 'FR')))",
        "queryParams": [
          "{{ $node[\"02. Parser\"].json.tenantId }}",
