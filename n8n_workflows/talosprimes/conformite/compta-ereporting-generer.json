    },
    {
      "parameters": {
        "jsCode": "// Aggregate transactions by TVA rate\nconst transactions = $input.all()[0].json;\nconst aggregated = {};\nlet totalHT = 0, totalTVA = 0, totalTTC = 0, count = 0;\n\nif (Array.isArray(transactions)) {\n  transactions.forEach(t => {\n    const rate = t.taux_tva || 'standard';\n    if (!aggregated[rate]) aggregated[rate] = { ht: 0, tva: 0, ttc: 0, count: 0 };\n    aggregated[rate].ht += parseFloat(t.montant_ht || 0);\n    aggregated[rate].tva += parseFloat(t.montant_tva || 0);\n    aggregated[rate].ttc += parseFloat(t.montant_ttc || 0);\n    aggregated[rate].count += 1;\n    totalHT += parseFloat(t.montant_ht || 0);\n    totalTVA += parseFloat(t.montant_tva || 0);\n    totalTTC += parseFloat(t.montant_ttc || 0);\n    count += 1;\n  });\n}\n\nreturn {\n  transactions: aggregated,\n  totalHT: totalHT,\n  totalTVA: totalTVA,\n  totalTTC: totalTTC,\n  count: count\n};"
      },
