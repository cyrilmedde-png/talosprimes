    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"UPDATE e_reportings SET statut = 'transmis', date_transmission = NOW() WHERE id = '\" + $json.ereportingId + \"' RETURNING *\" }}"
      },
