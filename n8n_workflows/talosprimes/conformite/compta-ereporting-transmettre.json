        "query": "INSERT INTO pistes_audit (id, tenant_id, action, entite, entite_id, donnees, date_action) VALUES (gen_random_uuid(), $1, 'TRANSMISSION_EREPORTING', 'e_reportings', $2, $3, NOW())",
        "queryParams": [
          "{{ $node[\"06. Prepare Payload\"].json.tenantId }}",
