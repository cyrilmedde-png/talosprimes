    {
      "parameters": {
        "jsCode": "// Prepare transmission payload for PPF API\nconst record = $input.all()[0].json[0];\nconst payload = {\n  type: record.type,\n  periodeDebut: record.periode_debut,\n  periodeFin: record.periode_fin,\n  nombreTransactions: record.nombre_transactions,\n  montantTotalHT: record.montant_total_ht,\n  montantTotalTVA: record.montant_total_tva,\n  montantTotalTTC: record.montant_total_ttc,\n  donnees: JSON.parse(record.donnees)\n};\n\nreturn {\n  payload: payload,\n  ereportingId: record.id,\n  tenantId: record.tenant_id\n};"
      },
      "id": "06. Prepare Payload",
      "name": "06. Prepare Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
