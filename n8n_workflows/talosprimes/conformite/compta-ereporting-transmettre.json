      "parameters": {
        "jsCode": "const body = $input.all()[0].json.body;\nconst uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\n\nif (!body.tenantId || !uuidRegex.test(body.tenantId)) {\n  throw new Error('Invalid or missing tenantId');\n}\nif (!body.ereportingId || !uuidRegex.test(body.ereportingId)) {\n  throw new Error('Invalid or missing ereportingId');\n}\n\nreturn {\n  tenantId: body.tenantId,\n  ereportingId: body.ereportingId\n};"
      },
      "id": "02. Parser",
      "name": "02. Parser",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
