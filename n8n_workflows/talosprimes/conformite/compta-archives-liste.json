    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, type_document, reference_document, annee_fiscale, date_archivage, duree_conservation, date_expiration, hash_integrite, statut, chemin_stockage, taille_octets, metadata, created_at FROM archives_comptables WHERE tenant_id = {{ $json.tenantId }}\n{% if $json.type %}\n  AND type_document = '{{ $json.type }}'\n{% endif %}\n{% if $json.annee %}\n  AND annee_fiscale = {{ $json.annee }}\n{% endif %}\nORDER BY date_archivage DESC\nLIMIT {{ $json.limit }} OFFSET {{ ($json.page - 1) * $json.limit }}",
        "options": {}
      },
