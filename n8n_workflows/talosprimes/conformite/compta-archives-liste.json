        "query": "SELECT COUNT(*) as total FROM archives_comptables WHERE tenant_id = {{ $json.tenantId }}\n{% if $json.type %}\n  AND type_document = '{{ $json.type }}'\n{% endif %}\n{% if $json.annee %}\n  AND annee_fiscale = {{ $json.annee }}\n{% endif %}",
        "options": {}
