    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\n\nif (!uuidRegex.test(body.tenantId)) {\n  throw new Error('Invalid tenantId format');\n}\n\nreturn [{ json: {\n  tenantId: body.tenantId,\n  type: body.type || null,\n  annee: body.annee || null,\n  page: body.page || 1,\n  limit: body.limit || 50\n} }];"
      },
      "id": "02. Parser",
      "name": "02. Parser",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "archives-val-tenant",
              "leftValue": "={{ $json.tenantId }}",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "03. Valide ?",
      "name": "03. Valide ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        500,
        200
      ]
    },
    {
      "parameters": {
        "responseBody": "={\n  \"success\": false,\n  \"error\": \"Invalid tenantId\"\n}",
        "respondWith": "json"
      },
      "id": "04. Respond Error",
      "name": "04. Respond Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        700,
        100
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"SELECT COUNT(*) as total FROM archives_comptables WHERE tenant_id = '\" + $json.tenantId + \"'\" + ($json.type ? \" AND type_document = '\" + $json.type + \"'\" : \"\") + ($json.annee ? \" AND annee_fiscale = \" + $json.annee : \"\") }}",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      },
      "id": "05. Count",
      "name": "05. Count",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        700,
        200
      ],
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"SELECT id, type_document, reference_document, annee_fiscale, date_archivage, duree_conservation, date_expiration, hash_integrite, statut, chemin_stockage, taille_octets, metadata, created_at FROM archives_comptables WHERE tenant_id = '\" + $json.tenantId + \"'\" + ($json.type ? \" AND type_document = '\" + $json.type + \"'\" : \"\") + ($json.annee ? \" AND annee_fiscale = \" + $json.annee : \"\") + \" ORDER BY date_archivage DESC LIMIT \" + $json.limit + \" OFFSET \" + (($json.page - 1) * $json.limit) }}",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      },
      "id": "06. List",
      "name": "06. List",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        900,
        200
      ],
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "var countResult = $('05. Count').first();\nvar total = countResult && countResult.json ? parseInt(countResult.json.total || '0', 10) : 0;\nvar listItems = $input.all();\nvar data = listItems.map(function(item) { return item.json; }).filter(function(r) { return r && r.id; });\n\nreturn [{\n  json: {\n    success: true,\n    total: total,\n    count: data.length,\n    data: data\n  }\n}];"
      },
