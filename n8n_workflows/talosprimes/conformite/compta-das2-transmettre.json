    {
      "parameters": {
        "jsCode": "// Prepare TD-RCM/EFI payload for DGFiP transmission\nconst record = $input.all()[0].json[0];\nconst payload = {\n  annee_fiscale: record.annee_fiscale,\n  nombre_beneficiaires: record.nombre_beneficiaires,\n  montant_total: record.montant_total,\n  format: 'TD-RCM',\n  destination: 'EFI-TDFC',\n  timestamp: new Date().toISOString()\n};\n\nreturn {\n  payload: payload,\n  das2Id: record.id,\n  tenantId: record.tenant_id\n};"
      },
      "id": "06. Prepare Payload",
      "name": "06. Prepare Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "query",
        "query": "UPDATE declarations_das2 SET statut = 'transmise', date_transmission = NOW() WHERE id = $1 RETURNING *",
        "queryParams": [
          "{{ $node[\"06. Prepare Payload\"].json.das2Id }}"
        ],
        "alwaysOutputData": true,
        "continueOnFail": true
