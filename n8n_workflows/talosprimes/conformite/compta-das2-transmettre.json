      ],
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Prepare TD-RCM/EFI payload for DGFiP transmission\nconst record = $input.all()[0].json[0];\nconst payload = {\n  annee_fiscale: record.annee_fiscale,\n  nombre_beneficiaires: record.nombre_beneficiaires,\n  montant_total: record.montant_total,\n  format: 'TD-RCM',\n  destination: 'EFI-TDFC',\n  timestamp: new Date().toISOString()\n};\n\nreturn {\n  payload: payload,\n  das2Id: record.id,\n  tenantId: record.tenant_id\n};"
      },
      "id": "06. Prepare Payload",
      "name": "06. Prepare Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"UPDATE declarations_das2 SET statut = 'transmise', date_transmission = NOW() WHERE id = '\" + $json.das2Id + \"' RETURNING *\" }}"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      },
      "id": "07. Update Status",
      "name": "07. Update Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        1100,
        200
      ],
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"INSERT INTO pistes_audit (id, tenant_id, action, entite, entite_id, donnees, date_action) VALUES (gen_random_uuid(), '\" + $json.tenantId + \"', 'TRANSMISSION_DAS2', 'declarations_das2', '\" + $json.das2Id + \"', '\" + $json.payload) + \"', NOW())\" }}"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      },
      "id": "08. Log Audit",
