        "operation": "executeQuery",
        "resource": "query",
        "query": "SELECT * FROM declarations_das2 WHERE id = $1 AND tenant_id = $2",
        "queryParams": [
          "{{ $node[\"02. Parser\"].json.das2Id }}",
          "{{ $node[\"02. Parser\"].json.tenantId }}"
