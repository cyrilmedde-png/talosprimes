    {
      "parameters": {
        "responseBody": "={\"success\": false, \"message\": \"Invalid tenantId or das2Id\"}",
        "respondWith": "json"
      },
      "id": "04. Respond Error",
      "name": "04. Respond Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        700,
        100
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"SELECT * FROM declarations_das2 WHERE id = '\" + $json.das2Id + \"' AND tenant_id = '\" + $json.tenantId + \"'\" }}"
      },
      "credentials": {
        "postgres": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      },
      "id": "05. Get Record",
