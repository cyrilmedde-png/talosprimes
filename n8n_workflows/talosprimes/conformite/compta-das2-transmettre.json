      "parameters": {
        "operation": "executeQuery",
        "resource": "query",
        "query": "INSERT INTO pistes_audit (id, tenant_id, action, entite, entite_id, donnees, date_action) VALUES (gen_random_uuid(), $1, 'TRANSMISSION_DAS2', 'declarations_das2', $2, $3, NOW())",
        "queryParams": [
          "{{ $node[\"06. Prepare Payload\"].json.tenantId }}",
          "{{ $node[\"06. Prepare Payload\"].json.das2Id }}",
          "{{ JSON.stringify($node[\"06. Prepare Payload\"].json.payload) }}"
        ],
