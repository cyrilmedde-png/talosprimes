      "parameters": {
        "jsCode": "// Prepare EDIFACT payload for DGFiP transmission\nconst record = $input.all()[0].json[0];\nconst payload = {\n  type_declaration: record.type_declaration,\n  periode_debut: record.periode_debut,\n  periode_fin: record.periode_fin,\n  tva_collectee: record.tva_collectee,\n  tva_deductible: record.tva_deductible,\n  tva_nette: record.tva_nette,\n  donnees_edifact: JSON.parse(record.donnees_edifact)\n};\n\nreturn {\n  payload: payload,\n  ediTvaId: record.id,\n  tenantId: record.tenant_id\n};"
      },
