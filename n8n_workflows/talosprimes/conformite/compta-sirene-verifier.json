    {
      "parameters": {
        "jsCode": "const body = $input.all()[0].json.body;\nconst uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\n\nif (!body.tenantId || !uuidRegex.test(body.tenantId)) {\n  throw new Error('Invalid or missing tenantId');\n}\nif (!body.siret || !/^\\d{14}$/.test(body.siret)) {\n  throw new Error('Invalid SIRET format (must be 14 digits)');\n}\n\nreturn {\n  tenantId: body.tenantId,\n  siret: body.siret\n};"
      },
      "id": "02. Parser",
      "name": "02. Parser",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": [
            {
              "key": "tenantId",
              "value": "",
              "operation": "notEmpty"
            }
          ]
        }
      },
      "id": "03. Valide ?",
      "name": "03. Valide ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        500,
        200
      ]
    },
    {
      "parameters": {
        "respondWithCode": 400,
        "responseBody": "{\"success\": false, \"message\": \"Invalid tenantId or SIRET\"}"
      },
      "id": "04. Respond Error",
      "name": "04. Respond Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        700,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "// Validate SIRET format and Luhn algorithm\nconst siret = $node[\"02. Parser\"].json.siret;\n\n// Luhn algorithm check\nlet sum = 0;\nlet doubled = false;\nfor (let i = siret.length - 1; i >= 0; i--) {\n  let digit = parseInt(siret[i], 10);\n  if (doubled) {\n    digit *= 2;\n    if (digit > 9) digit -= 9;\n  }\n  sum += digit;\n  doubled = !doubled;\n}\n\nconst isValid = (sum % 10) === 0;\n\nif (!isValid) {\n  throw new Error('Invalid SIRET: Luhn algorithm check failed');\n}\n\nreturn {\n  siret: siret,\n  luhn_valid: isValid\n};"
      },
      "id": "05. Validate SIRET",
      "name": "05. Validate SIRET",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Simulate API call to INSEE Sirene API\n// In production, replace with HTTP request to https://api.insee.fr/\nconst siret = $node[\"02. Parser\"].json.siret;\n\n// Mock response structure\nconst apiResponse = {\n  siret: siret,\n  siren: siret.substring(0, 9),\n  nic: siret.substring(9),\n  denomination: `Entreprise ${siret}`,\n  adresse: '123 Rue de la Paix',\n  code_postal: '75000',\n  ville: 'Paris',\n  code_naf: '6202A',\n  tranche_effectif: '10-19',\n  date_creation_etablissement: '2020-01-15',\n  etat_administratif: 'A',\n  nature_juridique: '5410',\n  timestamp_verification: new Date().toISOString()\n};\n\nreturn apiResponse;"
      },
      "id": "06. Query API",
      "name": "06. Query API",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
