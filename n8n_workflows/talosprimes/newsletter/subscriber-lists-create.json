        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst tenantId = body.tenantId;\nconst nom = body.nom;\nconst description = body.description || null;\nconst type = body.type || 'static';\nconst couleur = body.couleur || '#000000';\nconst subscriberIds = body.subscriberIds || [];\n\nreturn [{ tenantId, nom, description, type, couleur, subscriberIds }];"
      },
      "id": "parser",
      "name": "Parser",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
