      "typeVersion": 1,
      "position": [850, 450]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO subscriber_lists (tenant_id, nom, description, type, couleur)\nVALUES ($1::uuid, $2, $3, $4, $5)\nRETURNING id, tenant_id as tenantId, nom, description, type, couleur, created_at as createdAt, updated_at as updatedAt",
        "queryParams": "={{ [$json.tenantId, $json.nom, $json.description, $json.type, $json.couleur] }}",
        "credentials": {
          "id": "OGqj65ZoFRileCck",
          "name": "Supabase Postgres"
        }
      },
      "id": "query_create_list",
