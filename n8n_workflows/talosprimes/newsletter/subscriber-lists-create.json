    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO subscriber_list_members (list_id, subscriber_id)\nSELECT $1::uuid, unnest($2::uuid[])\nON CONFLICT (list_id, subscriber_id) DO NOTHING",
        "queryParams": "={{ [$json.listId, $json.subscriberIds] }}",
        "credentials": {
          "id": "OGqj65ZoFRileCck",
