      },
      "id": "01. Webhook",
      "name": "01. Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 200]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst tenantId = body.tenantId;\nconst nom = body.nom;\nconst description = body.description || null;\nconst type = body.type || 'static';\nconst couleur = body.couleur || '#000000';\nconst subscriberIds = body.subscriberIds || [];\n\nfunction esc(v) {\n  return v == null ? 'NULL' : \"'\" + String(v).replace(/'/g, \"''\") + \"'\";\n}\n\nlet sql = `INSERT INTO subscriber_lists (tenant_id, nom, description, type, couleur) VALUES (${esc(tenantId)}, ${esc(nom)}, ${esc(description)}, ${esc(type)}, ${esc(couleur)}) RETURNING id, tenant_id as tenantId, nom, description, type, couleur, created_at as createdAt, updated_at as updatedAt`;\n\nreturn { sql, subscriberIds };"
      },
      "id": "02. Parser",
      "name": "02. Parser",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [300, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "leftValue": ""},
          "conditions": [{"id": "check", "leftValue": "={{ $('02. Parser').first().json.sql }}", "operator": {"type": "string", "operation": "notEmpty"}}],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "03. Valide ?",
      "name": "03. Valide ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [500, 200]
    },
    {
      "parameters": {
        "respondWithOptions": {"responseType": "json"},
        "responseBody": "{ \"success\": false, \"error\": \"Validation failed\" }"
      },
      "id": "04. Respond Error",
      "name": "04. Respond Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [700, 100]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ $('02. Parser').first().json.sql }}"
      },
      "id": "05. Query",
      "name": "05. Query",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {"name": "Supabase Postgres", "id": "OGqj65ZoFRileCck"}
      },
      "position": [700, 300]
    },
    {
      "parameters": {
        "jsCode": "const listRow = $input.first().json[0] || $input.first().json;\nconst subscriberIds = $('02. Parser').first().json.subscriberIds || [];\n\nreturn { listId: listRow.id, subscriberIds, listRow };"
      },
      "id": "06. Check Subscribers",
      "name": "06. Check Subscribers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "leftValue": ""},
          "conditions": [{"id": "check", "leftValue": "={{ $json.subscriberIds.length }}", "operator": {"type": "number", "operation": ">"}, "value": 0}],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "07. Has Subscribers ?",
      "name": "07. Has Subscribers ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ 'INSERT INTO subscriber_list_members (list_id, subscriber_id) SELECT \\'' + $json.listId + '\\'::uuid, unnest(ARRAY[' + $json.subscriberIds.map(id => '\\'' + id + '\\''::uuid).join(',') + ']::uuid[]) ON CONFLICT (list_id, subscriber_id) DO NOTHING' }}"
      },
      "id": "08. Query Add Members",
      "name": "08. Query Add Members",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {"name": "Supabase Postgres", "id": "OGqj65ZoFRileCck"}
      },
      "position": [1300, 200]
    },
    {
      "parameters": {
        "jsCode": "const listRow = $json.listRow || $input.first().json;\n\nconst formatted = {\n  list: {\n    id: listRow.id,\n    tenantId: listRow.tenantId,\n    nom: listRow.nom,\n    description: listRow.description,\n    type: listRow.type,\n    couleur: listRow.couleur,\n    createdAt: listRow.createdAt,\n    updatedAt: listRow.updatedAt\n  }\n};\n\nreturn formatted;"
      },
      "id": "09. Format Response",
      "name": "09. Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 300]
