      "typeVersion": 4.1,
      "position": [850, 300]
    },
    {
      "parameters": {
        "jsCode": "const listRow = $input.first().json;\nconst listId = listRow.id;\nconst subscriberIds = $input.first().json._subscriberIds || [];\n\nreturn [{ listId, subscriberIds, listRow }];"
