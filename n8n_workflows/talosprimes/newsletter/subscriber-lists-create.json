            {
              "value1": "={{ $json.nom }}",
              "value2": "",
              "operation": "notEmpty"
            }
          ]
        }
      },
      "id": "validation",
      "name": "Validation",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
