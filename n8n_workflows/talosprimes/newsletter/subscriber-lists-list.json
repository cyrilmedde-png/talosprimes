      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst tenantId = body.tenantId;\n\nfunction esc(v) {\n  return v == null ? 'NULL' : \"'\" + String(v).replace(/'/g, \"''\") + \"'\";\n}\n\nconst sql = `SELECT sl.id, sl.tenant_id as tenantId, sl.nom, sl.description, sl.type, sl.couleur, sl.created_at as createdAt, sl.updated_at as updatedAt, COUNT(slm.subscriber_id) as memberCount FROM subscriber_lists sl LEFT JOIN subscriber_list_members slm ON sl.id = slm.list_id WHERE sl.tenant_id = ${esc(tenantId)} GROUP BY sl.id, sl.tenant_id, sl.nom, sl.description, sl.type, sl.couleur, sl.created_at, sl.updated_at ORDER BY sl.created_at DESC`;\n\nreturn { sql };"
      },
      "id": "02. Parser",
