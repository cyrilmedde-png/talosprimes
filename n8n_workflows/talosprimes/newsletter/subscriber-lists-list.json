          "options": {"caseSensitive": true, "leftValue": ""},
          "conditions": [{"id": "check", "leftValue": "={{ $('02. Parser').first().json.sql }}", "operator": {"type": "string", "operation": "notEmpty"}}],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "03. Valide ?",
      "name": "03. Valide ?",
