    {
      "parameters": {
        "jsCode": "const byStatusData = $node['query_by_status'].json.data || [];\nconst bySourceData = $node['query_by_source'].json.data || [];\nconst newLast30Data = $node['query_new_30days'].json.data || [];\nconst listsCountData = $node['query_lists_count'].json.data || [];\nconst totalCountData = $node['query_total_count'].json.data || [];\n\nconst byStatus = {};\nbyStatusData.forEach(row => {\n  byStatus[row.status] = parseInt(row.count) || 0;\n});\n\nconst bySource = {};\nbySourceData.forEach(row => {\n  bySource[row.source] = parseInt(row.count) || 0;\n});\n\nconst newLast30Days = newLast30Data.length > 0 ? parseInt(newLast30Data[0].count) || 0 : 0;\nconst totalLists = listsCountData.length > 0 ? parseInt(listsCountData[0].count) || 0 : 0;\nconst total = totalCountData.length > 0 ? parseInt(totalCountData[0].count) || 0 : 0;\n\nreturn [{\n  json: {\n    stats: {\n      total: total,\n      byStatus: {\n        active: byStatus['active'] || 0,\n        unsubscribed: byStatus['unsubscribed'] || 0,\n        bounced: byStatus['bounced'] || 0\n      },\n      bySource: {\n        lead: bySource['lead'] || 0,\n        client: bySource['client'] || 0,\n        contact_form: bySource['contact_form'] || 0,\n        manual: bySource['manual'] || 0,\n        import_csv: bySource['import_csv'] || 0\n      },\n      newLast30Days: newLast30Days,\n      totalLists: totalLists\n    }\n  }\n}];"
      },
