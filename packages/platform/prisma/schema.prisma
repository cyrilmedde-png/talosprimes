// LandingGlobalConfig (config globale: navbar, footer, seo, theme)
model LandingGlobalConfig {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String?      @map("tenant_id") @db.Uuid // null = global (plateforme)
  clientSpaceId  String?      @map("client_space_id") @db.Uuid // ID du ClientSpace (landing client)
  section        String       // "navbar", "footer", "seo", "theme"
  config         Json         @default("{}") // Toute la config
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant         Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientSpace    ClientSpace? @relation(fields: [clientSpaceId], references: [id], onDelete: Cascade)

  @@unique([clientSpaceId, section])
  @@index([tenantId])
  @@index([clientSpaceId])
  @@index([section])
  @@map("landing_global_config")
