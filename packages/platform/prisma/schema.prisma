  @@index([articleId])
  @@index([siteId])
  @@index([statut])
  @@map("stock_alerts")
}

// ============================================================
// Historique des conversations IA (n8n Postgres Chat Memory)
// Table utilisée par le nœud memoryPostgresChat de n8n
// Chiffrée AES-256 via trigger pour conformité RGPD
// ============================================================
model N8nChatHistory {
  id                Int       @id @default(autoincrement())
  sessionId         String    @map("session_id") @db.VarChar(255)
  message           Json      @map("message") @db.JsonB
  messageEncrypted  Bytes?    @map("message_encrypted")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("n8n_chat_histories")
}

// ============================================================
// Prévisionnel financier (pour clients ou interne)
// ============================================================

enum PrevisionnelStatut {
  brouillon
  valide
  archive
}

model Previsionnel {
  id                    String              @id @default(uuid()) @db.Uuid
  tenantId              String              @map("tenant_id") @db.Uuid
  clientFinalId         String?             @map("client_final_id") @db.Uuid

  nom                   String              @default("Prévisionnel") @db.VarChar(255)
  description           String?             @db.Text
  annee                 Int                 @default(2026)
  statut                PrevisionnelStatut  @default(brouillon)

  // Données complètes en JSONB (lignesCA, lignesCharges, investissements, financements, parametres)
  donnees               Json                @default("{}") @db.JsonB

  // Résultats dénormalisés pour listing rapide
  caAnnuel              Decimal             @default(0) @map("ca_annuel") @db.Decimal(12, 2)
  chargesAnnuelles      Decimal             @default(0) @map("charges_annuelles") @db.Decimal(12, 2)
  resultatExploitation   Decimal             @default(0) @map("resultat_exploitation") @db.Decimal(12, 2)
  seuilRentabilite      Decimal             @default(0) @map("seuil_rentabilite") @db.Decimal(12, 2)
  tresorerieFinale      Decimal             @default(0) @map("tresorerie_finale") @db.Decimal(12, 2)

  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientFinal           ClientFinal?        @relation(fields: [clientFinalId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([clientFinalId])
  @@index([annee])
  @@index([statut])
  @@map("previsionnels")
}

