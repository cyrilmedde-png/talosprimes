// ============================================
// RGPD / GDPR COMPLIANCE
// ============================================

// Registre des consentements RGPD (Art. 7 RGPD)
// Chaque entrée est immuable : on ne modifie jamais, on ajoute un nouvel enregistrement.
model ConsentLog {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  userId      String?       @map("user_id") @db.Uuid       // Utilisateur ayant donné le consentement (null = lead/visiteur)
  email       String                                         // Email de la personne concernée
  consentType ConsentType   @map("consent_type")
  action      ConsentAction                                  // granted / withdrawn
  version     String        @default("1.0")                  // Version de la politique acceptée
  ipAddress   String?       @map("ip_address")               // IP au moment du consentement
  userAgent   String?       @map("user_agent") @db.Text      // User-Agent du navigateur
  createdAt   DateTime      @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([consentType])
  @@index([createdAt])
  @@map("consent_logs")
}

// Demandes d'exercice de droits RGPD (Art. 15-22)
model RgpdRequest {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  email       String                                       // Email du demandeur
  type        String                                       // export | anonymize | delete | rectify | restrict
  status      String   @default("pending")                 // pending | processing | completed | rejected
  details     String?  @db.Text                            // Détails de la demande
  completedAt DateTime? @map("completed_at")
  completedBy String?  @map("completed_by") @db.Uuid       // User admin qui a traité
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("rgpd_requests")
}

// Registre des sous-traitants (Art. 28 RGPD)
model DataProcessor {
  id           String   @id @default(uuid()) @db.Uuid
  name         String                                      // Nom du sous-traitant
  purpose      String   @db.Text                           // Finalité du traitement
  dataTypes    String[] @default([]) @map("data_types")    // Types de données partagées
  country      String                                      // Pays d'hébergement
  dpaSignedAt  DateTime? @map("dpa_signed_at")             // Date de signature du DPA
  dpaUrl       String?  @map("dpa_url")                    // Lien vers le DPA
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("data_processors")
}

// Lead (demande d'inscription)
model Lead {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String?    @map("tenant_id") @db.Uuid
  nom         String?
  prenom      String?
  email       String?
  telephone   String
  statut      LeadStatus @default(nouveau)
  source      String?    @default("formulaire_inscription")
  notes       String?    @db.Text
  dateContact   DateTime?  @map("date_contact") @db.Timestamptz(6)
  dateEntretien DateTime?  @map("date_entretien") @db.Timestamptz(6)
  typeEntretien String?    @map("type_entretien") // telephonique, visioconference, physique
  // Pipeline prospect
  score            Int       @default(0) @map("score") // 0-100 qualification score
  derniereRelance  DateTime? @map("derniere_relance") @db.Timestamptz(6)
  nombreRelances   Int       @default(0) @map("nombre_relances")
  // Partenaire apporteur
  partnerId        String?   @map("partner_id") @db.Uuid
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner        Partner?        @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  callLogs       CallLog[]
  questionnaires Questionnaire[]

  @@index([email])
  @@index([tenantId])
  @@index([statut])
  @@index([createdAt])
  @@index([partnerId])
  @@index([score])
  @@map("leads")
}

// Notification (notifications dans la plateforme)
model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  type        String   // ex: "lead_inscription", "lead_questionnaire", "lead_entretien", "lead_confirmation", "client_creation"
  titre       String   @map("titre")
  message     String   @map("message") @db.Text
  donnees     Json?    @map("donnees") // Données additionnelles (leadId, clientId, etc.)
  lu          Boolean  @default(false) @map("lu")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([lu])
  @@index([createdAt])
  @@map("notifications")
}

// Testimonial (avis clients pour la landing page)
model Testimonial {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid // null = global (plateforme), sinon = tenant
  nom         String
  prenom      String
  entreprise  String?
  poste       String?  // ex: "CEO", "Directeur Commercial"
  avatar      String?  // URL ou initiales
  note        Int      @default(5) // Note sur 5
  commentaire String   @db.Text
  affiche     Boolean  @default(true) // Afficher ou masquer
  ordre       Int      @default(0) // Ordre d'affichage
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([affiche])
  @@index([ordre])
  @@map("testimonials")
}

// LandingContent (contenu éditable de la landing page)
model LandingContent {
  id          String   @id @default(uuid()) @db.Uuid
  section     String   @unique // ex: "hero_title", "hero_subtitle", "feature_1_title"
  contenu     String   @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([section])
  @@map("landing_content")
}

// CmsPage (pages dynamiques créées depuis l'admin)
model CmsPage {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique // ex: "tarifs", "a-propos", "faq"
  titre     String
  contenu   String   @db.Text // Markdown ou HTML
  metaTitle String?  @map("meta_title")
  metaDesc  String?  @map("meta_description") @db.Text
  publie    Boolean  @default(false)
  ordre     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([publie])
  @@index([ordre])
  @@map("cms_pages")
}

// LandingSection (sections configurables de la landing page)
model LandingSection {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String?      @map("tenant_id") @db.Uuid // null = global (plateforme)
  clientSpaceId  String?      @map("client_space_id") @db.Uuid // ID du ClientSpace (landing client)
  type           String       // "hero", "stats", "modules", "agent_ia", "how_it_works", "testimonials", "upcoming", "cta", "contact", "trust_badges", "custom_html", "integrations"
  titre          String?      // Titre interne (pour le dashboard)
  config         Json         @default("{}") // Toute la config de la section (textes, couleurs, items, etc.)
  ordre          Int          @default(0)
  actif          Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant         Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientSpace    ClientSpace? @relation(fields: [clientSpaceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientSpaceId])
  @@index([ordre])
  @@index([actif])
  @@map("landing_sections")
