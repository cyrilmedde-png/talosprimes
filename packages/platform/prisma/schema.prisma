// ============================================
// PARTENAIRES & COMMISSIONS (White-Label)
// ============================================

// Partenaire (revendeur / apporteur d'affaires / white-label)
model Partner {
  id                     String        @id @default(uuid()) @db.Uuid
  nom                    String
  email                  String        @unique
  telephone              String?
  raisonSociale          String        @map("raison_sociale")
  siret                  String        @map("siret")     // OBLIGATOIRE — conformité légale
  siren                  String        @map("siren")     // OBLIGATOIRE — conformité légale
  adresse                String?       @db.Text
  type                   PartnerType   @default(apporteur_affaires)
  commissionTauxNiveau1  Decimal       @default(10) @map("commission_taux_niveau1") @db.Decimal(5, 2)  // % sur clients directs
  commissionTauxNiveau2  Decimal       @default(3)  @map("commission_taux_niveau2") @db.Decimal(5, 2)  // % sur sous-clients
  statut                 PartnerStatus @default(actif)
  // White-label
  domainePersonnalise    String?       @map("domaine_personnalise") // ex: app.mondomaine.com
  logoBase64             String?       @map("logo_base64") @db.Text
  couleurPrimaire        String?       @map("couleur_primaire")     // hex color
  nomAffiche             String?       @map("nom_affiche")          // nom affiché à la place de TalosPrimes
  // Stripe Connect (pour paiement automatique au partenaire)
  stripeConnectId        String?       @map("stripe_connect_id")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  // Relations
  leads              Lead[]
  clientsApportes    ClientFinal[]
  commissions        Commission[]

  @@index([email])
  @@index([siret])
  @@index([statut])
  @@index([type])
  @@map("partners")
}

// Commission (calculée automatiquement à chaque paiement)
model Commission {
  id                  String           @id @default(uuid()) @db.Uuid
  partnerId           String           @map("partner_id") @db.Uuid
  clientFinalId       String?          @map("client_final_id") @db.Uuid
  niveau              Int              @default(1) @map("niveau") // 1 = client direct (10%), 2 = sous-client (3%)
  type                CommissionType   @default(abonnement_mensuel)
  montantBaseHt       Decimal          @map("montant_base_ht") @db.Decimal(10, 2)  // montant du paiement client
  tauxApplique        Decimal          @map("taux_applique") @db.Decimal(5, 2)     // taux effectif appliqué
  montantCommission   Decimal          @map("montant_commission") @db.Decimal(10, 2)
  statut              CommissionStatus @default(en_attente)
  datePaiement        DateTime?        @map("date_paiement") @db.Timestamptz(6)
  stripeTransferId    String?          @map("stripe_transfer_id")
  mois                String           @map("mois") // "2026-03" pour agrégation mensuelle
  createdAt           DateTime         @default(now()) @map("created_at")

  // Relations
  partner     Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  clientFinal ClientFinal? @relation(fields: [clientFinalId], references: [id], onDelete: SetNull)

  @@index([partnerId])
  @@index([clientFinalId])
  @@index([statut])
  @@index([mois])
  @@index([niveau])
  @@map("commissions")
}

// Événement de revenu (chaque paiement = 1 ligne)
model RevenueEvent {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String?     @map("tenant_id") @db.Uuid
  clientFinalId   String?     @map("client_final_id") @db.Uuid
  partnerId       String?     @map("partner_id") @db.Uuid
  type            RevenueType
  montantHt       Decimal     @map("montant_ht") @db.Decimal(10, 2)
  montantTtc      Decimal     @map("montant_ttc") @db.Decimal(10, 2)
  description     String?     @db.Text
  stripePaymentId String?     @map("stripe_payment_id")
  mois            String      @map("mois") // "2026-03"
  createdAt       DateTime    @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([clientFinalId])
  @@index([partnerId])
  @@index([mois])
  @@index([type])
  @@map("revenue_events")
}

